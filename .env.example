# URL base do emulador Key Vault (kvemu)
KEYVAULT_EMULATOR_URL=https://localhost:13000

# Domínio base para hostnames dos vaults (ex: prod.kvemu.local:13000)
KEYVAULT_BASE_DOMAIN=kvemu.local

# Nome do vault padrão
KEYVAULT_DEFAULT_VAULT=vault

# Tenant ID usado no fluxo OAuth2 client_credentials contra o AAD fake do kvemu
KEYVAULT_TENANT_ID=a0c2a3f5-e1b3-4d6a-9c41-2cdd1f2c7e0f

# Título exibido ao lado de "Key Vault Emulator" no cabeçalho da interface.
# Ex.: KEYVAULT_TITLE="Meu KeyVault" -> "Key Vault Emulator - Meu KeyVault"
KEYVAULT_TITLE="One Keyvault"
